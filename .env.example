# Application
CAMPUSVOICE_ENV=development
CAMPUSVOICE_LOG_LEVEL=INFO
CAMPUSVOICE_TIMEZONE=Asia/Shanghai
CAMPUSVOICE_SINGLE_USER_ID=user_demo

# API and browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CAMPUSVOICE_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database (relative to services/api when launched there)
CAMPUSVOICE_DATABASE_URL=sqlite+aiosqlite:///./campusvoice.db
CAMPUSVOICE_DATABASE_AUTO_CREATE=false

# ASR: disabled | funasr | whisper
CAMPUSVOICE_ASR_PROVIDER=disabled
CAMPUSVOICE_ASR_DEVICE=cpu
CAMPUSVOICE_ASR_MODEL=paraformer-zh-streaming
CAMPUSVOICE_ASR_VAD_MODEL=fsmn-vad
CAMPUSVOICE_ASR_PUNC_MODEL=ct-punc

# OpenAI-compatible LLM endpoint. Never commit a real key.
CAMPUSVOICE_LLM_BASE_URL=
CAMPUSVOICE_LLM_API_KEY=
CAMPUSVOICE_LLM_MODEL=

# Knowledge retrieval: lexical | embedding (embedding requires the AI extra)
CAMPUSVOICE_KNOWLEDGE_RETRIEVER=lexical
CAMPUSVOICE_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CAMPUSVOICE_EMBEDDING_DEVICE=cpu

# Docker image build. Use variant=cpu with the /whl/cpu index for a CPU-only AI image.
CAMPUSVOICE_DOCKER_INSTALL_AI=false
CAMPUSVOICE_PYTORCH_VERSION=2.11.0
CAMPUSVOICE_PYTORCH_VARIANT=cu130
CAMPUSVOICE_PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
