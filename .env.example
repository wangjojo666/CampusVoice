# Application
CAMPUSVOICE_ENV=development
CAMPUSVOICE_LOG_LEVEL=INFO
CAMPUSVOICE_TIMEZONE=Asia/Shanghai

# Authentication. Demo is allowed only in development/test.
CAMPUSVOICE_AUTH_MODE=demo
CAMPUSVOICE_DEMO_USER_ID=user_demo
CAMPUSVOICE_JWT_ISSUER=
CAMPUSVOICE_JWT_AUDIENCE=
CAMPUSVOICE_JWT_JWKS_URL=
CAMPUSVOICE_JWT_ALGORITHMS=["RS256"]
CAMPUSVOICE_JWT_LEEWAY_SECONDS=30
CAMPUSVOICE_WEBSOCKET_TICKET_TTL_SECONDS=30
CAMPUSVOICE_CONFIRMATION_CHALLENGE_TTL_SECONDS=120
# Production must inject a secret-manager value of at least 32 characters:
# CAMPUSVOICE_CONFIRMATION_SECRET=replace-with-a-random-production-secret

# API and browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CAMPUSVOICE_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Database (relative to services/api when launched there)
CAMPUSVOICE_DATABASE_URL=sqlite+aiosqlite:///./campusvoice.db
CAMPUSVOICE_DATABASE_AUTO_CREATE=false

# Privacy and retention. Raw audio persistence is intentionally unsupported.
CAMPUSVOICE_STORE_RAW_AUDIO=false
CAMPUSVOICE_TRANSCRIPTION_RETENTION_DAYS=30
CAMPUSVOICE_CORRECTION_RETENTION_DAYS=30
CAMPUSVOICE_CONVERSATION_RETENTION_DAYS=7
CAMPUSVOICE_PENDING_ACTION_RETENTION_DAYS=30
CAMPUSVOICE_AUDIT_RETENTION_DAYS=180
CAMPUSVOICE_PRIVACY_DELETION_CHALLENGE_TTL_SECONDS=120

# ASR: disabled | funasr | whisper
CAMPUSVOICE_ASR_PROVIDER=disabled
CAMPUSVOICE_ASR_DEVICE=cpu
CAMPUSVOICE_ASR_MODEL=paraformer-zh-streaming
CAMPUSVOICE_ASR_VAD_MODEL=fsmn-vad
CAMPUSVOICE_ASR_PUNC_MODEL=ct-punc
CAMPUSVOICE_ASR_MAX_FRAME_BYTES=131072
CAMPUSVOICE_ASR_MAX_CONTROL_MESSAGE_BYTES=32768
CAMPUSVOICE_ASR_IDLE_TIMEOUT_SECONDS=30
CAMPUSVOICE_ASR_MAX_SESSION_SECONDS=600
CAMPUSVOICE_ASR_MAX_AUDIO_SECONDS=300
CAMPUSVOICE_ASR_MAX_CONNECTIONS_PER_USER=1

# OpenAI-compatible LLM endpoint. Never commit a real key.
CAMPUSVOICE_LLM_BASE_URL=
CAMPUSVOICE_LLM_API_KEY=
CAMPUSVOICE_LLM_MODEL=

# Knowledge retrieval: lexical | embedding (embedding requires the AI extra)
CAMPUSVOICE_KNOWLEDGE_RETRIEVER=lexical
CAMPUSVOICE_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
CAMPUSVOICE_EMBEDDING_DEVICE=cpu

# Docker image build. Use variant=cpu with the /whl/cpu index for a CPU-only AI image.
CAMPUSVOICE_DOCKER_INSTALL_AI=false
CAMPUSVOICE_PYTORCH_VERSION=2.11.0
CAMPUSVOICE_PYTORCH_VARIANT=cu130
CAMPUSVOICE_PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
