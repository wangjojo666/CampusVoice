{
  "name": "campusvoice",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @campusvoice/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @campusvoice/web test:e2e",
    "test:coverage": "pnpm -r test:coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.5"
  }
}
